{
  "name": "@jimicze/opencode-tps",
  "version": "0.1.0",
  "description": "Real-time token speed metrics (PP and TG) displayed in the OpenCode sidebar",
  "type": "module",
  "exports": {
    "./tui": {
      "import": "./.opencode/plugins/tps-plugin.tsx"
    }
  },
  "engines": {
    "opencode": "^1.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p .opencode/tsconfig-check.json --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tps",
    "tokens",
    "speed",
    "metrics"
  ],
  "license": "MIT",
  "author": "jimicze",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimicze/opencode-plugin-tps.git"
  },
  "bugs": {
    "url": "https://github.com/jimicze/opencode-plugin-tps/issues"
  },
  "homepage": "https://github.com/jimicze/opencode-plugin-tps#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".opencode/plugins/tps-plugin.tsx",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "vitest": "^1.6.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
